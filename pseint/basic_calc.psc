Algoritmo basic_calc
	//Decalre variables or constants
	Definir num1, num2, add, subs, mult, div Como Entero
	//Assing variables or constants
	num<-0
	num2<-0
	add<-0
	subs<-0
	mult<-0
	div<-0
	//Inpusts
	num1<-10
	num2<-5
	//Processes
	add<-num1+num2
	subs<-num1-num2
	mult<-num1*num2
	div<-num1/num2
	//Outputs
	Escribir "The addition is:", add
	Escribir "The subtraction is:", subs
	Escribir "The multiplication is:", mult
	Escribir "The division is:", div
FinAlgoritmo
